# ── Application ────────────────────────────────────
APP_NAME=TransitOps
APP_VERSION=1.0.0
DEBUG=False

# ── Database (SQLite for dev / switch to PostgreSQL for prod) ───────────────
DATABASE_URL=sqlite:///./transitops.db
DATABASE_URL=postgresql+psycopg2://postgres:530208@localhost:5432/TransitOps

# ── JWT Security ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_DEPLOYING_USE_A_64_CHAR_RANDOM_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
